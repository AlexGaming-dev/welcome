rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /pages/{pageId} {
      allow read: if true;
      allow update: if request.auth != null && (request.auth.uid == resource.data.ownerUid || request.auth.uid == "i4Ivzb3NmtXt8ljWKOgGv92obY02");
    }
    match /verification_requests/{id} {
      allow read: if request.auth.uid == "i4Ivzb3NmtXt8ljWKOgGv92obY02";
      allow create: if request.auth != null;
    }
    match /shortlinks/{id} {
      allow read: if true;
      allow create: if request.auth != null;
    }
  }
}