    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Rajdhani:wght@300;500;700&family=Fira+Code:wght@400;500&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --primary-black: #050505;
            --accent-blue: #00f2ff;
            --accent-purple: #bc13fe;
            --text-main: #e0e0e0;
        }

        body {
            font-family: 'Rajdhani', sans-serif;
            background-color: var(--primary-black);
            color: var(--text-main);
            overflow-x: hidden;
            margin: 0;
            width: 100%;
        }

        h1, h2, h3, .nav-logo { font-family: 'Orbitron', sans-serif; }
        .mono { font-family: 'Fira Code', monospace; }

        .space-container {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: radial-gradient(circle at center, #0a0a0a 0%, #050505 100%);
            z-index: -1;
        }
        .star-layer { position: absolute; inset: 0; background-repeat: repeat; pointer-events: none; }

        #loader-wrapper {
            position: fixed; inset: 0; background: #090707;
            display: flex; flex-direction: column; align-items: center; justify-content: center; z-index: 1000;
            transition: opacity 0.6s ease;
        }
        .loader-3 { position: relative; width: 80px; height: 80px; border-radius: 50%; perspective: 800px; }
        .loader-3 .inner { position: absolute; width: 100%; height: 100%; border-radius: 50%; border-bottom: 3px solid var(--accent-blue); }
        .loader-3 .one { animation: rotate-one 1s linear infinite; }
        .loader-3 .two { animation: rotate-two 1s linear infinite; border-bottom: none; border-right: 3px solid var(--accent-purple); }
        .loader-3 .three { animation: rotate-three 1s linear infinite; border-bottom: none; border-top: 3px solid #fff; }

        @keyframes rotate-one { 0% { transform: rotateX(35deg) rotateY(-45deg) rotateZ(0deg); } 100% { transform: rotateX(35deg) rotateY(-45deg) rotateZ(360deg); } }
        @keyframes rotate-two { 0% { transform: rotateX(50deg) rotateY(10deg) rotateZ(0deg); } 100% { transform: rotateX(50deg) rotateY(10deg) rotateZ(360deg); } }
        @keyframes rotate-three { 0% { transform: rotateX(35deg) rotateY(55deg) rotateZ(0deg); } 100% { transform: rotateX(35deg) rotateY(55deg) rotateZ(360deg); } }

        .animated-dev {
            background: linear-gradient(90deg, #00f2ff, #bc13fe, #00f2ff);
            background-size: 200% auto;
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            animation: gradient-shift 3s linear infinite;
        }

        @keyframes gradient-shift {
            0% { background-position: 0% center; }
            100% { background-position: 200% center; }
        }

        .project-card, .contact-card {
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(15px);
            clip-path: polygon(0 0, 100% 0, 100% 90%, 95% 100%, 0 100%);
            transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .project-card:hover {
            border-color: var(--accent-blue);
            transform: translateY(-10px);
            background: rgba(0, 242, 255, 0.05);
            box-shadow: 0 0 30px rgba(0, 242, 255, 0.1);
        }

        .terminal-box {
            background: #0d0d0d;
            border: 1px solid #222;
            border-top: 25px solid #1a1a1a;
            position: relative;
            height: 250px;
            overflow-y: auto;
            scrollbar-width: none;
        }
        .terminal-box::-webkit-scrollbar { display: none; }
        .terminal-box::before { content: '● ● ●'; position: absolute; top: -18px; left: 10px; color: #444; font-size: 10px; }

        #terminal-input {
            background: transparent;
            border: none;
            outline: none;
            color: white;
            width: 100%;
        }

        @keyframes move-stars { from { transform: translateY(0); } to { transform: translateY(-1000px); } }
        
        .hero-logo-img {
            filter: drop-shadow(0 0 20px var(--accent-blue));
            animation: float 6s ease-in-out infinite;
        }
        @keyframes float {
            0%, 100% { transform: translateY(0px); }
            50% { transform: translateY(-20px); }
        }
    </style>
</head>
<body class="antialiased">

    <div class="space-container" id="space-bg"></div>

    <div id="loader-wrapper">
        <div class="loader-3 mb-8">
            <div class="inner one"></div>
            <div class="inner two"></div>
            <div class="inner three"></div>
        </div>
        <div class="mono text-xs text-blue-500 tracking-[0.5em] animate-pulse">LOADING...</div>
    </div>

    <nav class="fixed w-full z-50 px-4 md:px-8 py-4 flex justify-between items-center bg-black/60 backdrop-blur-xl border-b border-white/5">
        <div class="nav-logo text-lg md:text-xl font-black tracking-widest text-white flex items-center">
            <img src="https://www.alexgamingdev.tech/icons/favicon.png" class="w-6 h-6 md:w-8 md:h-8 mr-2 object-contain" alt="Logo">
            <span>alexgaming<span class="animated-dev">dev</span></span>
        </div>
        <div class="flex items-center gap-4">
            <select id="lang-toggle" class="bg-black border border-white/10 rounded px-2 py-1 text-[10px] md:text-xs text-cyan-400 focus:outline-none cursor-pointer uppercase font-bold">
                <option value="en">EN</option>
                <option value="de" selected>DE</option>
            </select>
        </div>
    </nav>

    <section id="hero" class="relative min-h-screen flex flex-col justify-center items-center px-6 pt-20 text-center">
        <div class="absolute w-[300px] md:w-[600px] h-[300px] md:h-[600px] bg-blue-600/5 rounded-full blur-[100px] md:blur-[150px] -z-10"></div>
        
        <div class="flex flex-col md:flex-row items-center mb-6 md:mb-10">
            <img src="https://www.alexgamingdev.tech/icons/favicon.png" class="hero-logo-img w-16 h-16 md:w-24 md:h-24 md:mr-4 mb-4 md:mb-0 object-contain" alt="Alexander Dennhoven Logo">
            <h1 id="hero-title" class="text-4xl md:text-7xl lg:text-9xl font-black leading-none tracking-tighter">
                alexgaming<span class="animated-dev">dev</span>
            </h1>
        </div>

        <p class="mono text-cyan-400 mb-8 text-xs md:text-sm tracking-[0.2em] md:tracking-[0.3em] uppercase opacity-80">Alexander Dennhoven | Software Architect & Developer</p>
        
        <div class="terminal-box p-4 md:p-6 w-full max-w-2xl mono text-xs md:text-base mb-12 shadow-2xl cursor-text text-left" onclick="document.getElementById('terminal-input').focus()">
            <div id="terminal-history" class="mb-2"></div>
            <div class="flex items-center">
                <span class="text-green-500 mr-2 shrink-0">root@alexgamingdev:~$</span>
                <input type="text" id="terminal-input" class="mono" autofocus autocomplete="off" placeholder="type 'help'...">
            </div>
        </div>

        <div class="flex flex-wrap justify-center gap-4">
            <a href="#portfolio" class="px-6 md:px-10 py-3 md:py-4 border border-cyan-500/50 hover:bg-cyan-500/10 transition-all font-bold uppercase tracking-[0.2em] text-cyan-400 text-xs md:text-sm" id="btn-text">
                Projekte ansehen
            </a>
            <a href="#contact" class="px-6 md:px-10 py-3 md:py-4 border border-purple-500/50 hover:bg-purple-500/10 transition-all font-bold uppercase tracking-[0.2em] text-purple-400 text-xs md:text-sm" id="btn-contact">
                Kontakt
            </a>
        </div>
    </section>

    <section id="about" class="py-16 px-6 max-w-7xl mx-auto">
        <h2 id="about-title" class="text-2xl md:text-3xl font-bold mb-8 tracking-[0.3em] md:tracking-[0.4em] uppercase border-l-4 border-cyan-400 pl-6 text-white">About</h2>
        <p id="about-p1" class="text-white/70 text-base md:text-lg leading-relaxed mb-6">Ich bin Software-Architekt und Entwickler mit Fokus auf <span class="text-cyan-400">.NET</span> und <span class="text-cyan-400">C#</span>. Meine Arbeit umfasst den Bau skalierbarer Anwendungen und Tools wie <a href="https://officeweb.alexgamingdev.tech" target="_blank" rel="noopener" class="text-white font-bold hover:text-cyan-400 transition-colors">Officeweb</a>, <a href="https://github.com/alexgamingdev/arch-it" target="_blank" rel="noopener" class="text-white font-bold hover:text-cyan-400 transition-colors">arch-it</a> und <strong class="text-white">sweep-it</strong>.</p>
        <a href="/about/" id="about-link" class="mono text-purple-400 hover:text-white transition-colors text-xs uppercase tracking-widest" aria-label="Mehr über mich">→ /about/</a>
    </section>

    <section id="portfolio" class="py-24 px-6 max-w-7xl mx-auto">
        <h2 id="section-title" class="text-2xl md:text-3xl font-bold mb-12 md:mb-20 tracking-[0.3em] md:tracking-[0.4em] uppercase border-l-4 border-cyan-400 pl-6 text-white">Software & Projekte</h2>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-10">
            <article>
                <a href="https://officeweb.alexgamingdev.tech" target="_blank" class="project-card p-6 md:p-8 flex flex-col md:flex-row gap-6 h-full">
                    <img src="data:image/svg+xml;base64," class="w-24 h-24 object-contain mx-auto md:mx-0" alt="Officeweb Logo">
                    <div>
                        <h3 class="text-xl md:text-2xl font-bold text-white mb-2">Officeweb</h3>
                        <p class="text-white/60 text-sm mb-4" id="desc-1">Browser-Office ohne Cloud. 100% Privacy. Kein Tracking.</p>
                    </div>
                </a>
            </article>

            <article>
                <a href="https://github.com/alexgamingdev/arch-it" target="_blank" class="project-card p-6 md:p-8 flex flex-col md:flex-row gap-6 h-full">
                    <img src="https://raw.githubusercontent.com/alexgamingdev/arch-it/main/assets/logo.png" class="w-24 h-24 object-contain mx-auto md:mx-0" alt="arch-it Logo">
                    <div>
                        <h3 class="text-xl md:text-2xl font-bold text-white mb-2">arch-it</h3>
                        <p class="text-white/60 text-sm mb-4" id="desc-2">CLI-Engine für automatisierte Projektstrukturen via JSON-Blueprints.</p>
                    </div>
                </a>
            </article>
        </div>
    </section>

    <section id="contact" class="py-24 px-6 max-w-7xl mx-auto">
        <h2 id="contact-title" class="text-2xl md:text-3xl font-bold mb-12 tracking-[0.3em] uppercase border-l-4 border-purple-500 pl-6 text-white">Kontakt</h2>
        <div class="contact-card p-8 md:p-12 text-center">
            <p class="mono text-cyan-400 mb-4">Direct Endpoint:</p>
            <a href="mailto:contact@alexgamingdev.tech" class="text-xl md:text-3xl font-bold hover:text-white transition-colors break-all">contact@alexgamingdev.tech</a>
        </div>
    </section>

    <footer class="py-12 text-center border-t border-white/5 opacity-40 text-[10px] uppercase tracking-widest">
        <div class="flex flex-wrap justify-center gap-6 mb-4">
            <a href="/impressum/">Impressum</a>
            <a href="/privacy/">Datenschutz</a>
            <a rel="me" href="https://mastodon.social/@alexgamingdev">Mastodon</a>
            <a href="https://bsky.app/profile/alexgamingdev.tech">Bluesky</a>
        </div>
        © 2026 | Alexander Dennhoven (alexgamingdev)
    </footer>

    <script>
        // Star Background
        const spaceBg = document.getElementById('space-bg');
        function createStars(count, size, duration) {
            const layer = document.createElement('div');
            layer.className = 'star-layer';
            let shadows = [];
            for(let i=0; i<count; i++) shadows.push(`${Math.random()*2000}px ${Math.random()*2000}px #fff`);
            layer.style.boxShadow = shadows.join(',');
            layer.style.width = size + 'px'; layer.style.height = size + 'px';
            layer.style.animation = `move-stars ${duration}s linear infinite`;
            spaceBg.appendChild(layer);
        }
        createStars(700, 1, 100); createStars(200, 2, 150);

        // Loader
        window.addEventListener('load', () => {
            setTimeout(() => {
                document.getElementById('loader-wrapper').style.opacity = '0';
                setTimeout(() => document.getElementById('loader-wrapper').style.display = 'none', 600);
            }, 1500);
        });

        // Language Switcher
        const langData = {
            en: { btn: "View Projects", btnC: "Contact", log: "Software & Projects", con: "Contact", d1: "Local-first browser office suite. Zero cloud. Zero tracking.", d2: "CLI scaffolding engine. JSON blueprints to file structures.", aboutTitle: "About", aboutP1: 'I am a software architect and developer focusing on <span class="text-cyan-400">.NET</span> and <span class="text-cyan-400">C#</span>. My work involves building scalable applications and tools like <a href="https://officeweb.alexgamingdev.tech" target="_blank" rel="noopener" class="text-white font-bold hover:text-cyan-400 transition-colors">Officeweb</a>, <a href="https://github.com/alexgamingdev/arch-it" target="_blank" rel="noopener" class="text-white font-bold hover:text-cyan-400 transition-colors">arch-it</a>, and <strong class="text-white">sweep-it</strong>.' },
            de: { btn: "Projekte ansehen", btnC: "Kontakt", log: "Software & Projekte", con: "Kontakt", d1: "Browser-Office ohne Cloud. 100% Privacy. Kein Tracking.", d2: "CLI-Engine für automatisierte Projektstrukturen via JSON-Blueprints.", aboutTitle: "About", aboutP1: 'Ich bin Software-Architekt und Entwickler mit Fokus auf <span class="text-cyan-400">.NET</span> und <span class="text-cyan-400">C#</span>. Meine Arbeit umfasst den Bau skalierbarer Anwendungen und Tools wie <a href="https://officeweb.alexgamingdev.tech" target="_blank" rel="noopener" class="text-white font-bold hover:text-cyan-400 transition-colors">Officeweb</a>, <a href="https://github.com/alexgamingdev/arch-it" target="_blank" rel="noopener" class="text-white font-bold hover:text-cyan-400 transition-colors">arch-it</a> und <strong class="text-white">sweep-it</strong>.' }
        };

        document.getElementById('lang-toggle').addEventListener('change', (e) => {
            const l = e.target.value;
            if(langData[l]) {
                document.getElementById('btn-text').innerText = langData[l].btn;
                document.getElementById('btn-contact').innerText = langData[l].btnC;
                document.getElementById('section-title').innerText = langData[l].log;
                document.getElementById('contact-title').innerText = langData[l].con;
                document.getElementById('desc-1').innerText = langData[l].d1;
                document.getElementById('desc-2').innerText = langData[l].d2;
                document.getElementById('about-title').innerText = langData[l].aboutTitle;
                document.getElementById('about-p1').innerHTML = langData[l].aboutP1;
                document.documentElement.lang = (l === 'de' ? 'de-DE' : 'en-US');
            }
        });

        // Terminal
        const terminalInput = document.getElementById('terminal-input');
        const terminalHistory = document.getElementById('terminal-history');
        const terminalBox = terminalInput.closest('.terminal-box');

        const commands = {
            help: () => [
                '<span class="text-cyan-400">Available commands:</span>',
                '  <span class="text-white">whoami</span>       — Identity info',
                '  <span class="text-white">about</span>        — About me',
                '  <span class="text-white">skills</span>       — Tech stack',
                '  <span class="text-white">projects</span>     — Software projects',
                '  <span class="text-white">contact</span>      — Contact info',
                '  <span class="text-white">social</span>       — Social links',
                '  <span class="text-white">clear</span>        — Clear terminal',
                '  <span class="text-white">ls</span>           — List sections',
            ],
            whoami: () => [
                '<span class="text-cyan-400">Alexander Dennhoven</span> <span class="text-white/40">(alexgamingdev)</span>',
                'Software Architect & Developer · Germany',
                '<span class="text-white/40">Wikidata: <a href="https://www.wikidata.org/wiki/Q138410440" target="_blank" class="text-cyan-400 hover:underline">Q138410440</a></span>',
            ],
            about: () => [
                '<span class="text-cyan-400">// About</span>',
                'Software Architect & Developer focusing on .NET and C#.',
                'Building scalable apps and tools like Officeweb, arch-it, sweep-it.',
                'Interested in local-first software & data sovereignty.',
                '<a href="/about/" class="text-purple-400 hover:underline">→ /about/</a>',
            ],
            skills: () => [
                '<span class="text-cyan-400">// Stack</span>',
                '<span class="text-green-400">Languages:</span>  C#  JavaScript  TypeScript',
                '<span class="text-green-400">Frameworks:</span> .NET  ASP.NET Core  Node.js',
                '<span class="text-green-400">Tooling:</span>    CLI Tools  Git  Linux',
                '<span class="text-green-400">Concepts:</span>   Local-first  Architecture  Automation',
            ],
            projects: () => [
                '<span class="text-cyan-400">// Projects</span>',
                '<a href="https://officeweb.alexgamingdev.tech" target="_blank" class="text-white font-bold hover:text-cyan-400 transition-colors">Officeweb</a>  — Local-first browser office suite. Zero cloud.',
                '<a href="https://github.com/alexgamingdev/arch-it" target="_blank" class="text-white font-bold hover:text-cyan-400 transition-colors">arch-it</a>    — CLI scaffolding engine. JSON blueprints to file structures.',
                '<span class="text-white font-bold">sweep-it</span>   — Coming soon.',
                '<a href="#portfolio" class="text-purple-400 hover:underline">→ #portfolio</a>',
            ],
            contact: () => [
                '<span class="text-cyan-400">// Contact</span>',
                'Email: <a href="mailto:contact@alexgamingdev.tech" class="text-cyan-400 hover:underline">contact@alexgamingdev.tech</a>',
                '<a href="/contact/" class="text-purple-400 hover:underline">→ /contact/</a>',
            ],
            social: () => [
                '<span class="text-cyan-400">// Social</span>',
                '<a href="https://github.com/alexgamingdev" target="_blank" class="text-white hover:text-cyan-400 transition-colors">GitHub</a>       github.com/alexgamingdev',
                '<a href="https://x.com/alexgamingdev" target="_blank" class="text-white hover:text-cyan-400 transition-colors">X (Twitter)</a>  @alexgamingdev',
                '<a href="https://bsky.app/profile/alexgamingdev.tech" target="_blank" class="text-white hover:text-cyan-400 transition-colors">Bluesky</a>      alexgamingdev.tech',
                '<a href="https://mastodon.social/@alexgamingdev" target="_blank" class="text-white hover:text-cyan-400 transition-colors">Mastodon</a>     @alexgamingdev@mastodon.social',
                '<a href="/about/" class="text-purple-400 hover:underline">→ /about/ for all links</a>',
            ],
            ls: () => [
                '<span class="text-cyan-400">./</span>',
                '  <a href="#hero" class="text-white hover:text-cyan-400">hero/</a>',
                '  <a href="#portfolio" class="text-white hover:text-cyan-400">portfolio/</a>',
                '  <a href="#contact" class="text-white hover:text-cyan-400">contact/</a>',
                '  <a href="/about/" class="text-white hover:text-cyan-400">about/</a>',
                '  <a href="/impressum/" class="text-white hover:text-cyan-400">impressum/</a>',
                '  <a href="/privacy/" class="text-white hover:text-cyan-400">privacy/</a>',
            ],
            clear: () => { terminalHistory.innerHTML = ''; return []; },
        };

        function appendLine(html, cls) {
            const line = document.createElement('div');
            line.className = 'leading-relaxed ' + (cls || '');
            line.innerHTML = html;
            terminalHistory.appendChild(line);
        }

        function runCommand(cmd) {
            const trimmed = cmd.trim().toLowerCase();
            appendLine(
                `<span class="text-green-500">root@alexgamingdev:~$</span> <span class="text-white">${cmd.replace(/</g,'&lt;').replace(/>/g,'&gt;')}</span>`
            );
            if (!trimmed) { scrollTerminal(); return; }
            if (commands[trimmed]) {
                const output = commands[trimmed]();
                (output || []).forEach(line => appendLine(line, 'text-white/70 pl-2'));
            } else {
                appendLine(`<span class="text-red-400">command not found: ${trimmed.replace(/</g,'&lt;')}. Type <span class="text-cyan-400">help</span> for commands.</span>`, 'pl-2');
            }
            scrollTerminal();
        }

        function scrollTerminal() {
            terminalBox.scrollTop = terminalBox.scrollHeight;
        }

        terminalInput.addEventListener('keydown', (e) => {
            if (e.key === 'Enter') {
                const val = terminalInput.value;
                terminalInput.value = '';
                runCommand(val);
            }
        });

        // Boot sequence
        window.addEventListener('load', () => {
            setTimeout(() => {
                const bootLines = [
                    '<span class="text-cyan-400">alexgamingdev terminal v1.0</span>',
                    '<span class="text-white/40">Type <span class="text-cyan-400">help</span> to see available commands.</span>',
                ];
                bootLines.forEach(line => appendLine(line, 'pl-2'));
                scrollTerminal();
            }, 1600);
        });
    </script>
</body>
</html>
